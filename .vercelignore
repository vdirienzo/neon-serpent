# Vercel ignore — files NOT to upload to deployment
# See: https://vercel.com/docs/concepts/projects/ignoring-files

# Vercel uses vercel.json for headers (not _headers)
_headers

# node_modules is auto-installed by Vercel (we have installCommand)
node_modules/

# Tests (not needed at runtime)
tests/
*.test.js
*.test.ts
*.spec.js
*.spec.ts

# Local config that should not affect Vercel
.vscode/
.idea/
.github/
.husky/
audit/

# Build artifacts (locally only; Vercel builds fresh)
dist/
build/
coverage/

# Docs and dev-only files
*.md
!README.md
.eslintcache
*.log
.DS_Store
Thumbs.db
*.bak
*.tmp
*.temp

# Git
.git/
.gitignore
.gitattributes

# Env files
.env
.env.local
.env.*.local

# IDE
*.swp
*.swo
*~

# Vercel deploy guide (not needed in production)
/DEPLOY_VERCEL.md
