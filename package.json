{
  "name": "neon-serpent",
  "version": "2.0.0",
  "description": "NEØN SERPENT — Refactored modular snake game (2026 SOTA)",
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 8765",
    "test": "node --test 'tests/**/*.test.js'",
    "test:vitest": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.js",
    "format": "prettier --write \"src/**/*.{ts,js,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,css,json,md}\"",
    "typecheck": "tsc --noEmit",
    "serve": "python3 -m http.server 8765"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "happy-dom": "^15.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
